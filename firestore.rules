rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── users collection ─────────────────────────────────────────────────────
    // Only the authenticated owner can read or write their own document.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // ── leaderboard collection ────────────────────────────────────────────────
    // Any authenticated user can read leaderboard entries.
    // Only the authenticated owner can write their own entry.
    match /leaderboard/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── problem-reports collection ──────────────────────────────────────────
    // Any user (including guests) can create reports.
    // Temporarily allow anyone to read reports for admin testing
    match /problem-reports/{reportId} {
      allow create: if true;  // Allow anyone to submit reports
      allow read, update: if true;  // Temporarily allow anyone to read for admin testing
    }

    // Block all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
